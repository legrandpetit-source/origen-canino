# .env.example — Copia este archivo como ".env" para desarrollo local
# NO subas el archivo .env a GitHub

# Base de datos: deja vacío para usar SQLite local, o pon tu URL de PostgreSQL
DATABASE_URL=

# Clave secreta para JWT (cambia por una cadena aleatoria larga en producción)
JWT_SECRET=cambia_esto_por_un_secreto_seguro_en_produccion

# Dominio adicional permitido en CORS (opcional)
ALLOWED_ORIGIN=https://legrandpetit-source.github.io
